/// Hello!
manifest dev {
    byte-order: LE,
    buffer-address-type: u8,
    command-address-type: u8,
    register-address-type: u8,

    /// Test
    device Foo {
        byte-order: BE,

        register Bar {
            address: 0,
            fields: fieldset a {
                size-bits: 16,
                byte-order: LE,
                bit-overlap: allow,
            },
        },

        extern lol -> u32 {
            infallible: allow,
        },

        /// LOL
        buffer BUF {
            address: 0,
            access: RO,
        },

        /// Test
        enum MyEnum -> i8 {
            /// Docs for A
            // lol
            /// More docs
            A: -1,
            B: 0,
            C: default 5,
        },

        command MyCommand {
            address: 42,
            address-overlap: allow,
            repeat: <MyEnum by 1>,
            fields-in: a,
            fields-out: a,
        }
    }
}