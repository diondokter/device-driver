device Device {
    byte-order: LE,
    register-address-type: u32,

    fieldset Foo {
        size-bits: 0
    },

    register Foo0[100*1000] {
        address: 0,
        fields: Foo,
    },
    register Foo1[100*1000] {
        address: 1,
        fields: Foo,
    },
    register Foo2[100*1000] {
        address: 2,
        fields: Foo,
    },
    register Foo3[100*1000] {
        address: 3,
        fields: Foo,
    },
    register Foo4[100*1000] {
        address: 4,
        fields: Foo,
    },
    register Foo5[100*1000] {
        address: 5,
        fields: Foo,
    },
    register Foo6[100*1000] {
        address: 6,
        fields: Foo,
    },
    register Foo7[100*1000] {
        address: 7,
        fields: Foo,
    },
    register Foo8[100*1000] {
        address: 8,
        fields: Foo,
    },
    register Foo9[100*1000] {
        address: 9,
        fields: Foo,
    }
}
