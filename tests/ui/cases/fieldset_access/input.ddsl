device Device {
    byte-order: LE,
    register-address-type: u8,
    register foo_ro {
        access: RO,
        address: 0,
        fields: fieldset foo_roFieldSet {
            size-bits: 64,

            field value_ro RO 15:0 -> uint,
            field value_rw 31:16 -> int,
            field value_wo WO 32 -> bool,
        }
    },
    register foo_rw {
        address: 1,
        fields: fieldset foo_rwFieldSet {
            size-bits: 64,

            field value_ro RO 15:0 -> uint,
            field value_rw 31:16 -> int,
            field value_wo WO 32 -> bool,
        }
    },
    register foo_wo {
        access: WO,
        address: 2,
        fields: fieldset foo_woFieldSet {
            size-bits: 64,
            field value_ro RO 15:0 -> uint,
            field value_rw 31:16 -> int,
            field value_wo WO 32 -> bool,
        }
    },
}
